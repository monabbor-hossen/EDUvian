rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow authenticated users to read and write routines
    match /routines/{batchId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow all authenticated users to search user profiles,
    // but only the owner can write their own document (e.g. academic_info)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chat groups: any logged-in user can create a group.
    // Read/update is open to authenticated users (member check is app-level).
    match /chats/{chatId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      // Members subcollection
      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
